# ============================================================
# Hybrid Cloud Pipeline - Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit the .env file to version control.
# ============================================================

# ----------------------------
# GCP Configuration
# ----------------------------
GCP_PROJECT_ID="your-gcp-project-id"
GCP_REGION="us-central1"
PATH_TO_GCP_KEYFILE="./path/to/your/keyfile.json"

# ----------------------------
# LocalStack / AWS Configuration
# ----------------------------
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=us-east-1
AWS_ENDPOINT_URL=http://localhost:4566

# ----------------------------
# Application Configuration
# ----------------------------
SQS_QUEUE_URL=http://localhost:4566/000000000000/data-processing-queue
GCP_PUBSUB_TOPIC=localstack-events
CLOUD_SQL_CONNECTION_NAME="your-gcp-project-id:us-central1:pipeline-sql-instance"
CLOUD_SQL_DB_NAME=pipelinedb
CLOUD_SQL_USER=pipeline_user
CLOUD_SQL_PASSWORD="your-secure-password"
DYNAMODB_TABLE_NAME=processed-records
